# Copy this file to .env and fill in your values. .env is gitignored.

# eBay developer keyset (https://developer.ebay.com > My Account > Keys)
# Standard keys unlock the Browse API (active listings only, ask prices).
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=

# sandbox or production. Use the matching keyset for the environment.
EBAY_ENV=sandbox

# Marketplace for Browse API searches.
EBAY_MARKETPLACE_ID=EBAY_US

# Marketplace Insights (sold comps via API) requires eBay partner approval.
# Leave false unless approved. Sold comps come from CSV import until then.
INSIGHTS_ENABLED=false

# Hosted Postgres (Railway). When a Postgres plugin is attached, Railway injects
# DATABASE_URL automatically; set it here only for local testing against Postgres.
# Leave unset to use the local SQLite file. postgres:// and postgresql:// URLs are
# accepted and rewritten to use the psycopg 3 driver.
# DATABASE_URL=

# Optional override for the SQLite file location. Defaults to data/cardtracker.db.
# Ignored when DATABASE_URL is set.
# DB_PATH=

# Google sign-in (hosted multi-user mode). Set all four to require login and give
# each user their own private collection. Leave unset for local single-owner mode.
# Create an OAuth client at https://console.cloud.google.com > Credentials, add the
# redirect URI below as an authorized redirect URI, then copy the client id/secret.
# AUTH_REDIRECT_URI=https://your-app.up.railway.app/oauth2callback
# AUTH_COOKIE_SECRET=  # any long random string, e.g. python -c "import secrets;print(secrets.token_hex(32))"
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# CLI owner bucket, so a local CLI collection stays separate in a shared database.
# CARDTRACKER_OWNER=local

# Fee model for the net-after-fees calculator. Defaults mirror eBay managed
# payments for trading cards. All optional.
# FEE_FINAL_VALUE_PCT=13.25
# FEE_PER_ORDER=0.30
# FEE_PROMOTED_PCT=0
# FEE_PAYMENT_PCT=0
# FEE_PAYMENT_FIXED=0
# FEE_FVF_ON_SHIPPING=true
# FEE_FVF_ON_TAX=true
